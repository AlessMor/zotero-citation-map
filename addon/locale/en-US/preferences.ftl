pref-citation-data-heading = Citation data
pref-citation-data-description = Configure how Zotero Citation Map retrieves and refreshes citation and reference information.

pref-automatic-updates =
    .label = Update citation data automatically

pref-provider = Citation data provider
pref-provider-auto =
    .label = Automatic (recommended)
pref-provider-openalex =
    .label = OpenAlex
pref-provider-semantic-scholar =
    .label = Semantic Scholar
pref-provider-crossref =
    .label = Crossref
pref-provider-opencitations =
    .label = OpenCitations
pref-provider-inspire =
    .label = INSPIRE-HEP

pref-provider-help = Automatic mode keeps OpenAlex work identities for the citation network when available and may use Crossref's larger publisher-deposited bibliography total for the References column.
pref-cache-days = Refresh data after this many days
pref-reference-count-note = The References column shows the provider's declared bibliography total. The plugin separately stores the structured references it can resolve for network construction, which can be fewer than the references printed in the paper.

pref-graph-appearance-heading = Graph appearance
pref-graph-appearance-description = Configure how papers are encoded in the citation network. Changes are applied to open Citation Map tabs immediately.

pref-node-size = Node size
pref-node-size-citations =
    .label = Citation count
pref-node-size-references =
    .label = Reference count
pref-node-size-uniform =
    .label = Same size

pref-node-label = Node label
pref-node-label-title =
    .label = Document title
pref-node-label-author-year =
    .label = First author, year

pref-collection-colors-note = Node colors identify top-level Zotero collections. Papers in nested collections inherit their top-level collection color; unfiled papers use a neutral color.

pref-citation-data-heading = 引文数据
pref-citation-data-description = 配置 Zotero Citation Map 获取和刷新引文及参考文献信息的方式。

pref-automatic-updates =
    .label = 自动更新引文数据

pref-provider = 引文数据提供方
pref-provider-auto =
    .label = 自动（推荐）
pref-provider-openalex =
    .label = OpenAlex
pref-provider-semantic-scholar =
    .label = Semantic Scholar
pref-provider-crossref =
    .label = Crossref
pref-provider-opencitations =
    .label = OpenCitations
pref-provider-inspire =
    .label = INSPIRE-HEP

pref-provider-help = 自动模式会尽可能保留 OpenAlex 的作品标识以构建引文网络，并可能使用 Crossref 提供的、更大的出版商参考文献总数显示在“参考文献”列中。
pref-cache-days = 在以下天数后刷新数据
pref-reference-count-note = “参考文献”列显示数据提供方声明的参考文献总数。插件会另行保存可解析的结构化参考文献用于构建网络，其数量可能少于论文中实际列出的参考文献。

pref-graph-appearance-heading = 图谱外观
pref-graph-appearance-description = 配置论文在引文网络中的显示方式。更改会立即应用到已打开的 Citation Map 标签页。

pref-node-size = 节点大小
pref-node-size-citations =
    .label = 引用次数
pref-node-size-references =
    .label = 参考文献数
pref-node-size-uniform =
    .label = 相同大小

pref-node-label = 节点标签
pref-node-label-title =
    .label = 文献标题
pref-node-label-author-year =
    .label = 第一作者，年份

pref-collection-colors-note = 节点颜色表示 Zotero 顶层分类。子分类中的论文继承其顶层分类颜色；未归类论文使用中性色。

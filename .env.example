# Usage:
# Copy this file as `.env` and fill in the variables below as instructed.

# If you are developing more than one plugin, you can store the bin path and
# profile path in system environment variables, which can be omitted here.

# The path of the Zotero binary file.
# The path delimiter should be escaped as `\\` for win32.
# The path is `*/Zotero.app/Contents/MacOS/zotero` for macOS.
ZOTERO_PLUGIN_ZOTERO_BIN_PATH=/path/to/zotero.exe

# The path of the profile used for development.
# Start the profile manager with `/path/to/zotero.exe -p` to create a profile.
# https://www.zotero.org/support/kb/profile_directory
ZOTERO_PLUGIN_PROFILE_PATH=/path/to/profile

# The directory where the Zotero database is located.
# Leave empty to use the profile's default data directory.
# https://www.zotero.org/support/zotero_data
ZOTERO_PLUGIN_DATA_DIR=

# Optional custom command used to terminate Zotero processes.
# ZOTERO_PLUGIN_KILL_COMMAND=

# GitHub token used only for local release publishing.
# GITHUB_TOKEN=
